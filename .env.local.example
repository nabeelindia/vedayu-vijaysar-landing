# =============================================
# VEDAYU — Environment Variables
# Copy this file to .env.local and fill values
# =============================================

# Razorpay (get from dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Razorpay Key ID (public — safe to expose in browser)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX

# Resend Email API (get from resend.com — free tier: 3000 emails/month)
RESEND_API_KEY=re_XXXXXXXXXXXX

# Your business email to receive order notifications
ORDERS_EMAIL=hivedayu@gmail.com

# WhatsApp support number (10 digits, no +91)
NEXT_PUBLIC_WHATSAPP_NUMBER=9876543210

# Site URL (your Vercel URL or custom domain)
NEXT_PUBLIC_SITE_URL=https://vedayu.com

# Supabase (for WhatsApp inbox — get from supabase.com > Settings > API)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
